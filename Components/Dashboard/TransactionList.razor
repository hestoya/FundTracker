<div class="container">
    <div class="d-flex gap-3 mb-3 w-100">
        <h2 class="text transaction text-nowrap fw-bold">RECENT TRANSACTIONS</h2>

        <div class="d-flex w-100 justify-content-between">
            <button class="transaction-btn">ADD TRANSACTION</button>
            <div class="d-flex gap-1 align-items-center">
                <label class="text sort">SORT BY</label>
                <button class="options-btn pb-1 pe-0">
                    <img src="assets/icons/caret-down-blue.svg" alt="Sort Options" class="icon" />
                </button>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column gap-3">
        <div class="d-flex flex-column gap-2">
            <div class="d-flex w-100 transaction-list align-items-center">
                <label class="text transaction-text w-50">Food</label>
                <span class="expense transaction-text w-50 text-end">-250.00</span>
            </div>

            <div class="d-flex w-100 transaction-list align-items-center">
                <label class="text transaction-text w-50">Salary</label>
                <span class="income transaction-text w-50 text-end">+7,000.00</span>
            </div>

            <div class="d-flex w-100 transaction-list align-items-center">
                <label class="text transaction-text w-50">Transport</label>
                <span class="expense transaction-text w-50 text-end">-75.00</span>
            </div>

            <div class="d-flex w-100 transaction-list align-items-center">
                <label class="text transaction-text w-50">Bills</label>
                <span class="expense transaction-text w-50 text-end">-1,150.00</span>
            </div>
        </div>

        <button class="text view-btn text-start">View More...</button>
    </div>
</div>

