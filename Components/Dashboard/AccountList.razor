<div class="container">
    <div class="d-flex gap-3 mb-3 w-100">
        <h2 class="text account text-nowrap fw-bold">ACCOUNTS</h2>

        <div class="d-flex w-100 justify-content-between">
            <button class="account-btn">ADD ACCOUNT</button>
            <div class="d-flex gap-1 align-items-center">
                <label class="text sort">SORT BY</label>
                <button class="options-btn pb-1 pe-0">
                    <img src="assets/icons/caret-down-blue.svg" alt="Sort Options" class="icon" />
                </button>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column gap-3">
        <div class="d-flex flex-column gap-2">
            <div class="d-flex w-100 bank-account">
                <div class="d-flex w-50 align-items-center gap-2">
                    <img src="assets/images/Maribank.png" alt="Maribank Logo" />
                    <label class="text bank-text">Maribank</label>
                </div>

                <span class="text bank-text w-50 text-end align-self-center">3,200.00</span>
            </div>

            <div class="d-flex w-100 bank-account">
                <div class="d-flex w-50 align-items-center gap-2">
                    <img src="assets/images/GoTyme.png" alt="GoTyme Logo" />
                    <label class="text bank-text">GoTyme</label>
                </div>

                <span class="text bank-text w-50 text-end align-self-center">2,298.00</span>
            </div>

            <div class="d-flex w-100 bank-account">
                <div class="d-flex w-50 align-items-center gap-2">
                    <img src="assets/images/Maya.png" alt="Maya PH Logo" />
                    <label class="text bank-text">Maya PH</label>
                </div>

                <span class="text bank-text w-50 text-end align-self-center">8,750.00</span>
            </div>

            <div class="d-flex w-100 bank-account">
                <div class="d-flex w-50 align-items-center gap-2">
                    <img src="assets/images/GCash.png" alt="GCash Logo" />
                    <label class="text bank-text">GCash</label>
                </div>

                <span class="text bank-text w-50 text-end align-self-center">1,000.00</span>
            </div>
        </div>

        <button class="text view-btn text-start">View More...</button>
    </div>
</div>

